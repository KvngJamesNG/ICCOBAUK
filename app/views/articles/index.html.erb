<%= render "partials/header" %>

<section class="py-5">
    <div class="container px-5">
        <div class="text-center mb-5">
            <h1 class="fw-bolder">Articles</h1>
            <p class="lead fw-normal text-muted mb-0">Latest stories and updates</p>
        </div>

        <div class="row g-4">
            <% @articles.each do |article| %>
            <div class="col-lg-4">
                <div class="card h-100 shadow border-0">
                    <% if article.feature_image.attached? %>
                    <%= image_tag article.feature_image, class: "card-img-top", alt: article.title %>
                    <% end %>
                    <div class="card-body p-4">
                        <div class="badge bg-primary bg-gradient rounded-pill mb-2"><%= article.category_label.presence || "News" %></div>
                        <%= link_to article_path(article), class: "text-decoration-none link-dark stretched-link" do %>
                        <h2 class="h5 card-title mb-3"><%= article.title %></h2>
                        <% end %>
                        <p class="card-text mb-0"><%= article.summary %></p>
                    </div>
                    <div class="card-footer p-4 pt-0 bg-transparent border-top-0">
                        <div class="small text-muted"><%= article.author&.name || article.author_name %> · <%= article.published_on %></div>
                    </div>
                </div>
            </div>
            <% end %>
        </div>
    </div>
</section>

<%= render "partials/footer" %>