<% admin_logged_in = session[:admin_authenticated] == true %>
<% admin_view = controller_path.start_with?("admin/") && admin_logged_in %>
<% path_segments = request.path.split("/").reject(&:blank?) %>
<% breadcrumb_segments = admin_view ? path_segments.drop(1) : path_segments %>
<% default_back_path = request.referer.presence || (admin_view ? admin_root_path : home_path) %>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container px-3 px-md-5">
        <a class="navbar-brand d-flex align-items-center" href="<%= admin_view ? admin_root_path : home_path %>">
            <%= image_tag "logo/favicon.ico", alt: "ICCOBA UK", class: "img-fluid", style: "height: clamp(44px, 8vw, 86px); width: auto;" %>
        </a>
        <% if admin_view %>
        <div class="ms-auto d-flex align-items-center">
            <%= button_to "Sign out", admin_logout_path, method: :delete, class: "btn btn-danger btn-sm" %>
        </div>
        <% else %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="<%= home_path %>">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="<%= about_us_path %>">About</a></li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" id="navbarDropdownBlog" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Blog</a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdownBlog">
                        <li><a class="dropdown-item" href="<%= blog_home_path %>">Blog Home</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" id="navbarDropdownPortfolio" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Gallery</a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdownPortfolio">
                        <li><a class="dropdown-item" href="<%= portfolio_overview_path %>">Gallery Overview</a></li>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link" href="<%= contact_us_path %>">Contact</a></li>
            </ul>
        </div>
        <% end %>
    </div>
</nav>

<nav class="bg-light border-bottom">
    <div class="container px-3 px-md-5 py-2 d-flex align-items-center justify-content-between flex-wrap gap-2">
        <ol class="breadcrumb mb-0 small">
            <% if admin_view %>
            <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
            <% else %>
            <li class="breadcrumb-item"><%= link_to "Home", home_path %></li>
            <% end %>

            <% path_accumulator = "" %>
            <% breadcrumb_segments.each_with_index do |segment, index| %>
            <% path_accumulator += "/#{segment}" %>
            <% label = segment.tr("-", " ").tr("_", " ").capitalize %>
            <% if index == breadcrumb_segments.length - 1 %>
            <li class="breadcrumb-item active" aria-current="page"><%= label %></li>
            <% else %>
            <li class="breadcrumb-item"><a href="<%= path_accumulator %>"><%= label %></a></li>
            <% end %>
            <% end %>
        </ol>
        <a href="<%= default_back_path %>" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>
</nav>

<% if admin_view %>
<aside class="admin-sidebar d-none d-lg-flex flex-column">
    <div class="admin-sidebar-header px-3 py-3 border-bottom">
        <h2 class="h6 mb-0 text-uppercase text-muted">Admin Panel</h2>
    </div>
    <div class="admin-sidebar-body p-2">
        <a class="admin-sidebar-link" href="<%= admin_root_path %>"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
        <a class="admin-sidebar-link" href="<%= admin_articles_path %>"><i class="bi bi-file-earmark-text me-2"></i>Articles</a>
        <a class="admin-sidebar-link" href="<%= admin_authors_path %>"><i class="bi bi-people me-2"></i>Authors</a>
        <a class="admin-sidebar-link" href="<%= admin_article_categories_path %>"><i class="bi bi-tags me-2"></i>Categories</a>
        <a class="admin-sidebar-link" href="<%= admin_gallery_images_path %>"><i class="bi bi-images me-2"></i>Gallery</a>
        <a class="admin-sidebar-link" href="<%= admin_slider_images_path %>"><i class="bi bi-sliders me-2"></i>Sliders</a>
        <a class="admin-sidebar-link" href="<%= admin_info_pages_path %>"><i class="bi bi-journal-richtext me-2"></i>Pages</a>
        <a class="admin-sidebar-link" href="<%= admin_site_setting_path %>"><i class="bi bi-gear me-2"></i>Settings</a>
        <a class="admin-sidebar-link" href="<%= articles_path %>"><i class="bi bi-globe me-2"></i>View Public Site</a>
    </div>
</aside>

<div class="d-lg-none bg-white border-bottom">
    <div class="container px-3 py-2 d-flex gap-2 overflow-auto">
        <a class="btn btn-sm btn-outline-secondary" href="<%= admin_root_path %>">Dashboard</a>
        <a class="btn btn-sm btn-outline-secondary" href="<%= admin_articles_path %>">Articles</a>
        <a class="btn btn-sm btn-outline-secondary" href="<%= admin_authors_path %>">Authors</a>
        <a class="btn btn-sm btn-outline-secondary" href="<%= admin_article_categories_path %>">Categories</a>
        <a class="btn btn-sm btn-outline-secondary" href="<%= admin_gallery_images_path %>">Gallery</a>
        <a class="btn btn-sm btn-outline-secondary" href="<%= admin_slider_images_path %>">Sliders</a>
        <a class="btn btn-sm btn-outline-secondary" href="<%= admin_info_pages_path %>">Pages</a>
    </div>
</div>
<% end %>