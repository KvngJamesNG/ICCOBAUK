<%= render "partials/header" %>
<!-- Page Content-->
<section class="py-5">
    <div class="container px-5 my-5">
        <div class="text-center mb-5">
            <h1 class="fw-bolder">ICCOBA UK/Europe Gallery</h1>
            <p class="lead fw-normal text-muted mb-0">Our Time Capsule</p>
        </div>

        <div class="row g-4">
            <% @gallery_images.each do |gallery_image| %>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow border-0">
                    <% if gallery_image.image.attached? %>
                    <%= image_tag gallery_image.image, class: "card-img-top", alt: gallery_image.title %>
                    <% end %>
                    <div class="card-body">
                        <h2 class="h5 card-title"><%= gallery_image.title %></h2>
                        <% if gallery_image.caption.present? %>
                        <p class="card-text text-muted mb-0"><%= gallery_image.caption %></p>
                        <% end %>
                    </div>
                </div>
            </div>
            <% end %>
        </div>

        <% if @gallery_images.empty? %>
        <p class="text-muted mt-4">No gallery images uploaded yet.</p>
        <% end %>
    </div>
</section>
<section class=" py-5 bg-light">
    <div class="container px-5 my-5">
        <h2 class="display-4 fw-bolder mb-4">Let's build something together</h2>
        <a class="btn btn-lg btn-primary" href="https://www.llw-cs.com">Contact us</a>
    </div>
</section>
<%= render "partials/footer" %>