<%= render "partials/header" %>

<header class="bg-dark py-5">
    <div class="container px-5">
        <div class="row gx-5 align-items-center justify-content-center">

            <div class="col-lg-8 col-xl-7 col-xxl-6">
                <div class="my-5 text-center text-xl-start">
                    <h1 class="display-5 fw-bolder text-white mb-3">Welcome to ICCOBA UK/Europe</h1>
                    <p class="lead fw-normal text-white-50 mb-4"><%= @site_setting.home_convention_text_value %></p>
                    <% if @site_setting.theme_document.attached? %>
                    <p class="mb-4">
                        <a href="<%= rails_blob_path(@site_setting.theme_document, disposition: "attachment") %>" target="_blank" class="btn btn-primary btn-lg fw-bold px-4 py-2 shadow-lg border-3 border-dark" style="text-decoration:none; font-size:1.25rem;">
                            <%= @site_setting.theme_document_title.presence || "Theme Document" %>
                            <i class="bi bi-arrow-right-circle ms-2"></i>
                        </a>
                    </p>
                    <% end %>
                    <p class="lead fw-normal text-white-50 mb-4"><%= @site_setting.home_sponsor_text_value %></p>
                    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center justify-content-xl-start">
                        <a class="btn btn-primary btn-lg px-4 me-sm-3" href="#features">Get Started</a>
                        <a class="btn btn-outline-light btn-lg px-4" href="<%= about_us_path %>">Learn More</a>
                    </div>
                </div>
            </div>
            <div class="col-xl-5 col-xxl-6 text-center">
                <div id="productCarousel" class="carousel slide my-5 rounded-3" data-bs-ride="carousel" data-bs-interval="3500" data-bs-pause="false" data-bs-touch="true">
                    <% if @slider_images.any? %>
                    <div class="carousel-indicators">
                        <% @slider_images.each_with_index do |_, index| %>
                        <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="<%= index %>" class="<%= "active" if index.zero? %>" <%= "aria-current=\"true\"" if index.zero? %> aria-label="Slide <%= index + 1 %>"></button>
                        <% end %>
                    </div>
                    <% end %>

                    <div class="carousel-inner rounded-3">
                        <% @slider_images.each_with_index do |slider_image, index| %>
                        <div class="carousel-item <%= "active" if index.zero? %>">
                            <% if slider_image.link_url.present? %>
                            <a href="<%= slider_image.link_url %>">
                                <%= image_tag slider_image.image, class: "d-block w-100", alt: slider_image.title, style: "height: 360px; object-fit: contain; background: #111;" %>
                            </a>
                            <% else %>
                            <%= image_tag slider_image.image, class: "d-block w-100", alt: slider_image.title, style: "height: 360px; object-fit: contain; background: #111;" %>
                            <% end %>
                        </div>
                        <% end %>
                    </div>

                    <% if @slider_images.empty? %>
                    <div class="text-white-50 small mt-3">No slider images yet. Add them from admin.</div>
                    <% else %>
                    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</header>
<!-- Features section-->
<section class="py-5" id="features">
    <div class="container px-5 my-5">
        <div class="row gx-5">
            <div class="col-lg-4 mb-5 mb-lg-0">
                <h2 class="fw-bolder mb-0">A Few Words About ICCOBA.</h2>
            </div>
            <div class="col-lg-8">
                <div class="row gx-5 row-cols-1 row-cols-md-2">
                    <div class="col mb-5 h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-book"></i></div>
                        <h2 class="h5">Honoring the Legacy</h2>
                        <p class="mb-0">The Immaculate Conception College Old Boys’ Association (ICCOBA) was first envisioned by Mr. Wilson Uwaifo in 1964. It began as a call to reconnect, support, and uplift the legacy of ICC Benin.</p>
                    </div>
                    <div class="col mb-5 h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-award"></i></div>
                        <h2 class="h5">A History of Excellence</h2>
                        <p class="mb-0">With a proud heritage spanning over 78 years, ICC Benin has shaped generations of men who have gone on to make meaningful contributions across various sectors worldwide.</p>
                    </div>
                    <div class="col mb-5 mb-md-0 h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-person-plus"></i></div>
                        <h2 class="h5">Who Can Join?</h2>
                        <p class="mb-0">Membership is open to all former students who spent at least three years at ICC Benin. Whether you're based in the UK or anywhere else, you're part of this family.</p>
                    </div>
                    <div class="col h-100">
                        <div class="feature bg-primary bg-gradient text-white rounded-3 mb-3"><i class="bi bi-archive"></i></div>
                        <h2 class="h5">Why It Matters</h2>
                        <p class="mb-0">ICCOBA exists to build community, preserve the school's values, support current students, and give back meaningfully together.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Testimonial section-->
<div class="py-5 bg-light">
    <div class="container px-5 my-5">
        <div class="row gx-5 justify-content-center">
            <div class="col-lg-10 col-xl-7">
                <div class="text-center">
                    <div class="fs-4 mb-4 fst-italic">"Being part of ICCOBA keeps me connected to my roots while making a real impact back home. Every project and event reminds me that together, we’re building more than memories, we’re shaping the future of ICC."</div>
                    <div class="d-flex align-items-center justify-content-center">
                        <%= image_tag "gallery/presidentworldwide40.jpg", class: "rounded-circle me-3", alt: "..." %>
                        <div class="fw-bold">
                            President,
                            <span class="fw-bold text-primary mx-1">/</span>
                            ICCOBA Worldwide
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Blog preview section-->
<section class="py-5">
    <div class="container px-5 my-5">
        <div class="row gx-5 justify-content-center">
            <div class="col-lg-8 col-xl-6">
                <div class="text-center">
                    <h2 class="fw-bolder">From our blog</h2>
                    <p class="lead fw-normal text-muted mb-5">Stay updated with the latest news, stories, and highlights from ICCOBAUK covering events, achievements, and community updates worldwide.</p>
                </div>
            </div>
        </div>
        <% if @latest_article.present? %>
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-lg overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <% if @latest_article.feature_image.attached? %>
                            <%= image_tag @latest_article.feature_image, class: "img-fluid h-100 w-100", alt: @latest_article.title, style: "object-fit: cover; min-height: 220px;" %>
                            <% else %>
                            <div class="h-100 d-flex align-items-center justify-content-center bg-dark text-white fw-semibold" style="min-height: 220px;">Latest Blog</div>
                            <% end %>
                        </div>
                        <div class="col-md-8">
                            <div class="card-body p-4 p-lg-5">
                                <span class="badge bg-success mb-3">Latest Article</span>
                                <h3 class="card-title mb-3"><%= @latest_article.title %></h3>
                                <p class="card-text text-muted mb-4"><%= @latest_article.summary %></p>
                                <a class="btn btn-dark" href="<%= article_path(@latest_article) %>">Read latest post</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% end %>
        <div class="row gx-5">
            <% @featured_articles.each do |article| %>
            <div class="col-lg-4 mb-5">
                <div class="card h-100 shadow border-0">
                    <% if article.feature_image.attached? %>
                    <%= image_tag article.feature_image, class: "card-img-top", alt: article.title %>
                    <% end %>
                    <div class="card-body p-4">
                        <div class="badge bg-primary bg-gradient rounded-pill mb-2"><%= article.category_label.presence || "News" %></div>
                        <a class="text-decoration-none link-dark stretched-link" href="<%= article_path(article) %>">
                            <h5 class="card-title mb-3"><%= article.title %></h5>
                        </a>
                        <p class="card-text mb-0"><%= article.summary %></p>
                    </div>
                    <div class="card-footer p-4 pt-0 bg-transparent border-top-0">
                        <div class="small">
                            <div class="fw-bold"><%= article.author&.name || article.author_name %></div>
                            <div class="text-muted"><%= article.published_on %></div>
                        </div>
                    </div>
                </div>
            </div>
            <% end %>

            <% if @featured_articles.empty? %>
            <div class="col-12">
                <p class="text-muted">No featured articles yet. Add content from admin.</p>
            </div>
            <% end %>

            <!-- Call to action-->
            <aside class="bg-primary bg-gradient rounded-3 p-4 p-sm-5 mt-5">
                <div class="d-flex align-items-center justify-content-between flex-column flex-xl-row text-center text-xl-start">
                    <div class="mb-4 mb-xl-0">
                        <div class="fs-3 fw-bold text-white">New products, delivered to you.</div>
                        <div class="text-white-50">Sign up for our newsletter for the latest updates.</div>
                    </div>
                    <div class="ms-xl-4">
                        <div class="input-group mb-2">
                            <input class="form-control" type="text" placeholder="Email address..." aria-label="Email address..." aria-describedby="button-newsletter" />
                            <button class="btn btn-outline-light" id="button-newsletter" type="button">Sign up</button>
                        </div>
                        <div class="small text-white-50">We care about privacy, and will never share your data.</div>
                    </div>
                </div>
            </aside>
        </div>
</section>
<%= render "partials/footer" %>