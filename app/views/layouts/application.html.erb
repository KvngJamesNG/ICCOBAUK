<!DOCTYPE html>
<html>

<head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload", preload_links_header: false %>
    <%= javascript_importmap_tags %>

    <!-- Bootstrap icons-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />

</head>

<body class="d-flex flex-column min-vh-100 <%= "admin-layout" if respond_to?(:admin_layout_active?) && admin_layout_active? %>">
    <% if notice.present? %>
    <div class="container px-5 mt-3">
        <div class="alert alert-success" role="alert"><%= notice %></div>
    </div>
    <% end %>

    <% if alert.present? %>
    <div class="container px-5 mt-3">
        <div class="alert alert-danger" role="alert"><%= alert %></div>
    </div>
    <% end %>

    <div id="app-content">
        <%= yield %>
    </div>
    <% unless respond_to?(:admin_layout_active?) && admin_layout_active? %>
    <%= render "partials/cookie_banner" %>
    <% end %>
</body>

</html>