<%= render "partials/header" %>
<%= render "partials/admin_page_header", title: "Gallery Images" %>

<section class="py-4">
    <div class="container px-5">
        <div class="d-flex justify-content-end gap-2 mb-3">
            <%= link_to "Manage Groups", admin_gallery_groups_path, class: "btn btn-outline-secondary" %>
            <%= link_to "New Image", new_admin_gallery_image_path, class: "btn btn-primary" %>
        </div>

        <% if @gallery_images.any? %>
        <div class="row g-4">
            <% @gallery_images.each do |gallery_image| %>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow">
                    <% if gallery_image.image.attached? %>
                    <%= image_tag gallery_image.image, class: "card-img-top", alt: gallery_image.title %>
                    <% end %>
                    <div class="card-body">
                        <h2 class="h5"><%= gallery_image.title %></h2>
                        <% if gallery_image.gallery_group.present? %>
                        <p class="mb-2"><span class="badge text-bg-primary"><%= gallery_image.gallery_group.name %></span></p>
                        <% end %>
                        <p class="text-muted mb-0"><%= gallery_image.caption %></p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        <%= link_to "View", admin_gallery_image_path(gallery_image), class: "btn btn-sm btn-outline-secondary" %>
                        <%= link_to "Edit", edit_admin_gallery_image_path(gallery_image), class: "btn btn-sm btn-outline-primary" %>
                        <%= link_to "Delete", admin_gallery_image_path(gallery_image), data: { turbo_method: :delete, turbo_confirm: "Delete this image?" }, class: "btn btn-sm btn-outline-danger" %>
                    </div>
                </div>
            </div>
            <% end %>
        </div>
        <% else %>
        <p class="text-muted">No gallery images yet.</p>
        <% end %>

        <%= link_to "Back to Dashboard", admin_root_path, class: "btn btn-link px-0 mt-3" %>
    </div>
</section>

<%= render "partials/footer" %>