<%= render "partials/header" %>

<section class="py-5">
    <div class="container px-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bolder mb-0">Manage Gallery Groups</h1>
            <div class="d-flex gap-2">
                <%= link_to "Back to Images", admin_gallery_images_path, class: "btn btn-outline-secondary" %>
                <%= link_to "New Group", new_admin_gallery_group_path, class: "btn btn-primary" %>
            </div>
        </div>

        <% if @gallery_groups.any? %>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Images</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% @gallery_groups.each do |gallery_group| %>
                    <tr>
                        <td><%= gallery_group.name %></td>
                        <td><%= gallery_group.gallery_images.size %></td>
                        <td class="text-end">
                            <%= link_to "View", admin_gallery_group_path(gallery_group), class: "btn btn-sm btn-outline-secondary" %>
                            <%= link_to "Edit", edit_admin_gallery_group_path(gallery_group), class: "btn btn-sm btn-outline-primary" %>
                            <%= link_to "Delete", admin_gallery_group_path(gallery_group), data: { turbo_method: :delete, turbo_confirm: "Delete this group? Images will remain and become ungrouped." }, class: "btn btn-sm btn-outline-danger ms-2" %>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
        <% else %>
        <p class="text-muted">No gallery groups created yet.</p>
        <% end %>
    </div>
</section>

<%= render "partials/footer" %>