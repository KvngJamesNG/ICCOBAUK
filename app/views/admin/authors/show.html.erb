<%= render "partials/header" %>
<%= render "partials/admin_page_header", title: @author.name, parent_title: "Authors", parent_path: admin_authors_path, back_path: admin_authors_path %>

<section class="py-4">
    <div class="container px-5" style="max-width: 760px;">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p><strong>Email:</strong> <%= @author.email.presence || "—" %></p>
                <p class="mb-0"><strong>Role:</strong> <%= @author.role.presence || "—" %></p>
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <%= link_to "Edit", edit_admin_author_path(@author), class: "btn btn-primary" %>
            <%= link_to "Back to Authors", admin_authors_path, class: "btn btn-outline-secondary" %>
        </div>
    </div>
</section>

<%= render "partials/footer" %>