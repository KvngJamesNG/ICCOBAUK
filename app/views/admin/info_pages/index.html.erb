<%= render "partials/header" %>

<section class="py-5">
    <div class="container px-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bolder mb-0">Manage Info Pages</h1>
            <%= link_to "New Info Page", new_admin_info_page_path, class: "btn btn-primary" %>
        </div>

        <% if @info_pages.any? %>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Slug</th>
                        <th>Published</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% @info_pages.each do |info_page| %>
                    <tr>
                        <td><%= info_page.title %></td>
                        <td><%= info_page.slug %></td>
                        <td><%= info_page.published ? "Yes" : "No" %></td>
                        <td class="text-end">
                            <%= link_to "View", admin_info_page_path(info_page), class: "btn btn-sm btn-outline-secondary" %>
                            <%= link_to "Edit", edit_admin_info_page_path(info_page), class: "btn btn-sm btn-outline-primary" %>
                            <%= link_to "Delete", admin_info_page_path(info_page), data: { turbo_method: :delete, turbo_confirm: "Delete this info page?" }, class: "btn btn-sm btn-outline-danger" %>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
        <% else %>
        <p class="text-muted">No info pages yet.</p>
        <% end %>

        <%= link_to "Back to Admin", admin_root_path, class: "btn btn-link px-0" %>
    </div>
</section>

<%= render "partials/footer" %>