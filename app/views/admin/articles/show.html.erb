<%= render "partials/header" %>
<%= render "partials/admin_page_header", title: @article.title, parent_title: "Articles", parent_path: admin_articles_path, back_path: admin_articles_path %>

<section class="py-4">
    <div class="container px-5" style="max-width: 900px;">
        <p class="text-muted mb-4"><%= @article.author_name %> · <%= @article.published_on %></p>

        <% if @article.feature_image.attached? %>
        <div class="mb-4">
            <%= image_tag @article.feature_image, class: "img-fluid rounded" %>
        </div>
        <% end %>

        <p class="lead"><%= @article.summary %></p>
        <div><%= simple_format(@article.body) %></div>

        <div class="mt-4 d-flex gap-2">
            <%= link_to "Edit", edit_admin_article_path(@article), class: "btn btn-primary" %>
            <% unless writer_signed_in? %>
            <%= link_to "Delete", admin_article_path(@article), data: { turbo_method: :delete, turbo_confirm: "Delete this article?" }, class: "btn btn-outline-danger" %>
            <% end %>
        </div>

        <%= link_to "Back to Articles", admin_articles_path, class: "btn btn-link px-0 mt-3" %>
    </div>
</section>

<%= render "partials/footer" %>