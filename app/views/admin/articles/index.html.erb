<%= render "partials/header" %>
<%= render "partials/admin_page_header", title: "Articles" %>

<section class="py-4">
    <div class="container px-5">
        <div class="d-flex justify-content-end mb-3">
            <%= link_to "New Article", new_admin_article_path, class: "btn btn-primary" %>
        </div>

        <% if @articles.any? %>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Published</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% @articles.each do |article| %>
                    <tr>
                        <td><%= article.title %></td>
                        <td><%= article.author_name %></td>
                        <td><%= article.published_on %></td>
                        <td class="text-end">
                            <%= link_to "View", admin_article_path(article), class: "btn btn-sm btn-outline-secondary" %>
                            <%= link_to "Edit", edit_admin_article_path(article), class: "btn btn-sm btn-outline-primary" %>
                            <% unless writer_signed_in? %>
                            <%= link_to "Delete", admin_article_path(article), data: { turbo_method: :delete, turbo_confirm: "Delete this article?" }, class: "btn btn-sm btn-outline-danger" %>
                            <% end %>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
        <% else %>
        <p class="text-muted">No articles yet.</p>
        <% end %>

        <%= link_to "Back to Dashboard", admin_root_path, class: "btn btn-link px-0" %>
    </div>
</section>

<%= render "partials/footer" %>