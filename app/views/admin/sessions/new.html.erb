<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div style="width: 100%; max-width: 460px;" class="px-3">

        <div class="text-center mb-4">
            <%= image_tag "logo/favicon.ico", alt: "ICCOBA UK", style: "height: 120px; width: auto;" %>
            <h1 class="h4 fw-bold mt-3 mb-0">ICCOBA UK Admin</h1>
            <p class="text-muted small mt-1">Sign in to manage your website</p>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <% if flash[:alert] %>
                <div class="alert alert-danger py-2 small"><%= flash[:alert] %></div>
                <% end %>

                <%= form_with url: admin_session_path, method: :post, local: true do %>
                <div class="mb-3">
                    <%= label_tag :username, "Username", class: "form-label fw-semibold" %>
                    <%= text_field_tag :username, params[:username], class: "form-control", required: true, autofocus: true, placeholder: "Enter username" %>
                </div>

                <div class="mb-4">
                    <%= label_tag :password, "Password", class: "form-label fw-semibold" %>
                    <%= password_field_tag :password, nil, class: "form-control", required: true, placeholder: "Enter password" %>
                </div>

                <div class="d-grid">
                    <%= submit_tag "Sign In", class: "btn btn-dark btn-lg w-100" %>
                </div>
                <% end %>
            </div>
        </div>

        <p class="text-center text-muted small mt-4">
            <%= link_to "← Back to website", home_path, class: "text-muted" %>
        </p>
    </div>
</div>