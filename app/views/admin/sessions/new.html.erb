<%= render "partials/header" %>

<section class="py-5">
    <div class="container px-5" style="max-width: 520px;">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-md-5">
                <h1 class="h3 fw-bolder mb-3">Admin Sign In</h1>
                <p class="text-muted mb-4">Use your admin credentials to access the dashboard.</p>

                <%= form_with url: admin_session_path, method: :post, local: true do %>
                <div class="mb-3">
                    <%= label_tag :username, "Username", class: "form-label" %>
                    <%= text_field_tag :username, params[:username], class: "form-control", required: true, autofocus: true %>
                </div>

                <div class="mb-4">
                    <%= label_tag :password, "Password", class: "form-label" %>
                    <%= password_field_tag :password, nil, class: "form-control", required: true %>
                </div>

                <div class="d-grid">
                    <%= submit_tag "Sign In", class: "btn btn-primary btn-lg" %>
                </div>
                <% end %>
            </div>
        </div>
    </div>
</section>

<%= render "partials/footer" %>